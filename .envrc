#!/usr/bin/env bash

set -euo pipefail

export TMP_SECRETS=$HOME/book-secrets/

function secrets_folder(){
    mkdir -p $TMP_SECRETS
    echo $TMP_SECRETS/${1}
}

export BW_SESSION=${BW_SESSION:-`bw unlock --raw` }

GH_FILE=$(secrets_folder "github")
bw get item security-book-github-personal-access-token --raw > $GH_FILE
export GH_PAT="$(cat $GH_FILE | jq -r '.fields[] | select(.name == "personal-access-token") | .value'  )"

AWS_FILE=$(secrets_folder "aws")
bw get item security-book-aws --raw > $AWS_FILE
export AWS_SECRET_ACCESS_KEY="$(cat $AWS_FILE | jq -r '.fields[] | select(.name == "access-key-secret") | .value'  )"
export AWS_ACCESS_KEY_ID="$(cat $AWS_FILE | jq -r '.fields[] | select(.name == "access-key-id") | .value'  )"

export GIT_USERNAME=joshlong
export GIT_PASSWORD=${GH_PAT}

rm -rf $TMP_SECRETS